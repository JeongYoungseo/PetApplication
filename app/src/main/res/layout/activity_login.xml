<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/bg_beige"
    android:padding="24dp">

    <!-- Top title pill -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🐶 멍냥케어 🐱"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:background="@drawable/bg_pill_white"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="40dp"
        android:elevation="2dp"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="로그인"
        android:textSize="20sp"
        android:textColor="@color/text_dark"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="아이디"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/et_login_id"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_beige"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:singleLine="true"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="비밀번호"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/et_login_pw"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_beige"
                    android:paddingHorizontal="16dp"
                    android:inputType="textPassword"
                    android:textSize="14sp"
                    android:singleLine="true"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <TextView
                    android:id="@+id/txt_signup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="회원가입"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:layout_marginEnd="16dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/bg_pill_primary_light"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"/>

                <Button
                    android:id="@+id/btn_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="로그인"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:background="@drawable/bg_pill_primary"
                    app:backgroundTint="@null"
                    android:minHeight="40dp"
                    android:paddingHorizontal="24dp"
                    style="?android:attr/borderlessButtonStyle"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>