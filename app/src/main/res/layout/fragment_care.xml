<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_beige"
    android:padding="20dp">

    <!-- Top title pill -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🐶 멍냥케어 🐱"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:background="@drawable/bg_pill_white"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="24dp"
        android:elevation="2dp"/>

    <!-- 1. 상단 제목 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="케어관리"
        android:textColor="@color/text_dark"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- 2. 탭 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnWalk"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="산책"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:background="@drawable/bg_pill_selector"
            app:backgroundTint="@null"
            android:minHeight="40dp"
            style="?android:attr/borderlessButtonStyle"/>

        <Button
            android:id="@+id/btnVaccine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="예방접종"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:background="@drawable/bg_pill_selector"
            app:backgroundTint="@null"
            android:minHeight="40dp"
            style="?android:attr/borderlessButtonStyle"/>

        <Button
            android:id="@+id/btnMemo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="메모"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:background="@drawable/bg_pill_selector"
            app:backgroundTint="@null"
            android:minHeight="40dp"
            style="?android:attr/borderlessButtonStyle"/>
    </LinearLayout>

    <!-- 3. 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCare"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="20dp"/>

    <!-- 4. 추가 버튼 (맨 아래 고정, 오른쪽 정렬 둥근 버튼) -->
    <Button
        android:id="@+id/btnAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:text="추가하기"
        android:textColor="@color/text_dark"
        android:textSize="14sp"
        android:background="@drawable/bg_pill_primary_light"
        app:backgroundTint="@null"
        android:paddingHorizontal="24dp"
        android:minHeight="40dp"
        style="?android:attr/borderlessButtonStyle"/>
</LinearLayout>