<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_beige"
    android:padding="20dp">

    <!-- Top title pill -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🐶 멍냥케어 🐱"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:background="@drawable/bg_pill_white"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="24dp"
        android:elevation="2dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="마이페이지"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:layout_marginBottom="16dp"/>

    <!-- ========================= -->
    <!-- 1. 프로필 카드 영역 -->
    <!-- ========================= -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 상단: 이미지 + 이름 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:cardCornerRadius="30dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/img_profile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@mipmap/ic_launcher"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tv_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="이름"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tv_subinfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="종 / 나이 / 몸무게"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray"/>
                </LinearLayout>

            </LinearLayout>

            <!-- 상태 정보 (태그) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_activity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="활동량"
                    android:textSize="10sp"
                    android:textColor="@color/tag_text"
                    android:background="@drawable/bg_tag_pill"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tv_health"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="건강상태"
                    android:textSize="10sp"
                    android:textColor="@color/tag_text"
                    android:background="@drawable/bg_tag_pill"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tv_allergy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="알러지"
                    android:textSize="10sp"
                    android:textColor="@color/tag_text"
                    android:background="@drawable/bg_tag_pill"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- ========================= -->
    <!-- 2. 메뉴 버튼 영역 -->
    <!-- ========================= -->

    <!-- 설정 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginBottom="12dp">
        <Button
            android:id="@+id/btn_setting"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="설정"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:gravity="center_vertical|start"
            android:paddingStart="24dp"
            android:drawableStart="@android:drawable/ic_menu_preferences"
            android:drawablePadding="16dp"
            android:background="@android:color/transparent"
            style="?android:attr/borderlessButtonStyle"
            app:drawableTint="@color/text_gray"/>
    </androidx.cardview.widget.CardView>

    <!-- 알림 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginBottom="12dp">
        <Button
            android:id="@+id/btn_notice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="알림"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:gravity="center_vertical|start"
            android:paddingStart="24dp"
            android:drawableStart="@android:drawable/ic_popup_reminder"
            android:drawablePadding="16dp"
            android:background="@android:color/transparent"
            style="?android:attr/borderlessButtonStyle"
            app:drawableTint="@color/text_gray"/>
    </androidx.cardview.widget.CardView>

    <!-- 고객센터 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginBottom="12dp">
        <Button
            android:id="@+id/btn_center"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="고객센터"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:gravity="center_vertical|start"
            android:paddingStart="24dp"
            android:drawableStart="@android:drawable/ic_menu_help"
            android:drawablePadding="16dp"
            android:background="@android:color/transparent"
            style="?android:attr/borderlessButtonStyle"
            app:drawableTint="@color/text_gray"/>
    </androidx.cardview.widget.CardView>

    <!-- 로그아웃 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginBottom="12dp">
        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="로그아웃"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:gravity="center_vertical|start"
            android:paddingStart="24dp"
            android:drawableStart="@android:drawable/ic_menu_revert"
            android:drawablePadding="16dp"
            android:background="@android:color/transparent"
            style="?android:attr/borderlessButtonStyle"
            app:drawableTint="@color/text_gray"/>
    </androidx.cardview.widget.CardView>

</LinearLayout>